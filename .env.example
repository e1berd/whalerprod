# Copy this file to `.env`.
# Dev values below are active by default. Production values are kept commented
# in the second half of the file; uncomment and replace them on the server.

# ---------------------------------------------------------------------------
# Development / local
# ---------------------------------------------------------------------------

# Supabase/Postgres for local Supabase CLI.
# Run `just supabase-status` after `just supabase-start` and copy the anon key.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_PUBLIC_URL=http://127.0.0.1:54321
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_URL_DOCKER=http://host.docker.internal:54321
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-supabase-status-anon-key

# Local service ports.
API_PORT=3000
COLLAB_PORT=3001
RUNNER_PORT=3002
VOICE_PORT=3003

# Browser-facing local URLs.
VITE_API_URL=http://localhost:3000
VITE_COLLAB_URL=ws://localhost:3001
VITE_VOICE_URL=ws://localhost:3003

# Voice/WebRTC local defaults.
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=auto
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=40100
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:auto:3478?transport=udp,turn:auto:3478?transport=tcp
TURN_STATIC_SECRET=dev-turn-secret-replace-in-prod
TURN_TTL_SECONDS=3600
TURN_REALM=whaler

# Runner and sandbox limits.
RUNNER_INTERNAL_URL=http://localhost:3002
RUNNER_INTERNAL_TOKEN=change-me-to-a-long-random-token
DOCKER_SOCKET_PATH=/var/run/docker.sock
SANDBOX_MEMORY_BYTES=536870912
SANDBOX_NANO_CPUS=1000000000
SANDBOX_PIDS_LIMIT=256
PREVIEW_NETWORK_NAME=whaler-preview
STAND_BASE_DOMAIN=localhost
STAND_PUBLIC_PORT=3002

# Docker Compose local defaults.
DATABASE_URL_DOCKER=postgres://postgres:postgres@host.docker.internal:54322/postgres
RUNNER_INTERNAL_URL_DOCKER=http://runner:3002
BASE_DOMAIN=localhost
APP_DOMAIN=localhost
API_DOMAIN=api.localhost
COLLAB_DOMAIN=collab.localhost
VOICE_DOMAIN=voice.localhost
SUPABASE_DOMAIN=supabase.localhost
STAND_BASE_DOMAIN_DOCKER=stand.localhost
CADDY_ACME_EMAIL=admin@example.com
SUPABASE_UPSTREAM=host.docker.internal:54321
APP_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Production template
# ---------------------------------------------------------------------------

# Supabase/Postgres.
# DATABASE_URL=postgres://postgres:strong-password@supabase-db:5432/postgres
# DATABASE_URL_DOCKER=postgres://postgres:strong-password@host.docker.internal:54322/postgres
# SUPABASE_PUBLIC_URL=https://supabase.example.com
# SUPABASE_URL_DOCKER=http://host.docker.internal:54321
# SUPABASE_JWT_SECRET=replace-with-production-supabase-jwt-secret
# VITE_SUPABASE_URL=https://supabase.example.com
# VITE_SUPABASE_ANON_KEY=replace-with-production-supabase-anon-key
# SUPABASE_UPSTREAM=host.docker.internal:54321

# Browser-facing production URLs. These are baked into the web image at build time.
# APP_ORIGIN=https://app.example.com
# VITE_API_URL=https://api.example.com
# VITE_COLLAB_URL=wss://collab.example.com
# VITE_VOICE_URL=wss://voice.example.com

# Public domains handled by Caddy.
# BASE_DOMAIN=example.com
# APP_DOMAIN=app.example.com
# API_DOMAIN=api.example.com
# COLLAB_DOMAIN=collab.example.com
# VOICE_DOMAIN=voice.example.com
# SUPABASE_DOMAIN=supabase.example.com
# STAND_BASE_DOMAIN=stand.example.com
# STAND_BASE_DOMAIN_DOCKER=stand.example.com
# CADDY_ACME_EMAIL=ops@example.com

# Voice/WebRTC production values.
# MEDIASOUP_LISTEN_IP=0.0.0.0
# MEDIASOUP_ANNOUNCED_IP=203.0.113.10
# MEDIASOUP_RTC_MIN_PORT=40000
# MEDIASOUP_RTC_MAX_PORT=40100
# STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:voice.example.com:3478?transport=udp,turn:voice.example.com:3478?transport=tcp
# TURN_STATIC_SECRET=replace-with-long-random-secret
# TURN_TTL_SECONDS=3600
# TURN_REALM=example.com

# Runner and sandbox production values.
# RUNNER_INTERNAL_URL_DOCKER=http://runner:3002
# RUNNER_INTERNAL_TOKEN=replace-with-long-random-token
# DOCKER_SOCKET_PATH=/var/run/docker.sock
# SANDBOX_MEMORY_BYTES=536870912
# SANDBOX_NANO_CPUS=1000000000
# SANDBOX_PIDS_LIMIT=256
# PREVIEW_NETWORK_NAME=whaler-preview

# Optional production wildcard TLS for preview hosts via acme.sh DNS-01.
# Set ACME_DNS_PROVIDER to any acme.sh-supported DNS provider and add that
# provider's required credentials. Beget example:
# ACME_DNS_PROVIDER=dns_beget
# ACME_IMAGE=neilpang/acme.sh:3.1.4
# Beget_Username=your-beget-login
# Beget_Password=your-beget-api-password
# Run `just stand-cert`, then set STAND_TLS_DIRECTIVE to the generated paths.
# STAND_TLS_DIRECTIVE="tls /acme-data/*.stand.example.com_ecc/fullchain.cer /acme-data/*.stand.example.com_ecc/*.stand.example.com.key"

# SMTP values for Supabase Auth production emails.
# Whaler does not send these emails itself; map these values into the
# self-hosted Supabase Auth/Gotrue service.
# MAIL_HOST=smtp.example.com
# MAIL_PORT=465
# MAIL_USERNAME=no-reply@example.com
# MAIL_PASSWORD=replace-with-smtp-password
# MAIL_FROM_ADDRESS=no-reply@example.com
# MAIL_FROM_NAME=Whaler
